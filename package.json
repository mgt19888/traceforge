{
  "name": "traceforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node --test packages/importer/src/index.test.mjs",
    "traceforge": "node packages/cli/src/main.js",
    "traceforge:ingest": "node packages/cli/src/main.js ingest fixtures/codex-session.json artifacts/latest-session.json",
    "traceforge:validate-fixtures": "node scripts/validate-fixtures.mjs",
    "traceforge:serve": "node packages/cli/src/main.js serve --trace artifacts/latest-session.json --port 4310"
  }
}
